# Copy to .env and fill in your values
# Create your Strava app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
# The Firebase Function URL — replace {region} and {project-id}
# Typically: https://us-central1-bigdawglifts-aa31a.cloudfunctions.net/stravaCallback
STRAVA_REDIRECT_URI=https://us-central1-bigdawglifts-aa31a.cloudfunctions.net/stravaCallback
# Your Firebase Hosting URL
APP_URL=https://bigdawglifts-aa31a.web.app
